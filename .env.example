# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Application Configuration
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_NAME=Money Manager India
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics (Optional)
NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id

# API Configuration
NEXT_PUBLIC_API_TIMEOUT=30000

# Email Configuration (for notifications, optional)
SENDGRID_API_KEY=your-sendgrid-api-key

# Loan Rate Scraping (for periodic updates)
LOAN_RATE_SCRAPER_ENABLED=true
LOAN_RATE_UPDATE_INTERVAL_HOURS=6

# Tax Content Sync
TAX_CONTENT_SYNC_ENABLED=true
TAX_CONTENT_UPDATE_INTERVAL_DAYS=7

# Security
NEXT_PUBLIC_SECURE_COOKIES=true
ENCRYPTION_KEY=your-encryption-key-32-chars-min

# Third-party Integrations
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
